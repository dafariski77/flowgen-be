# ─── Database (external instance) ───
DATABASE_URL=postgres://user:password@your-db-host:5432/flowgen

# ─── NestJS API ───
PORT=3000
JWT_SECRET=your-jwt-secret-change-me

# ─── Google OAuth ───
GOOGLE_CLIENT_ID=
